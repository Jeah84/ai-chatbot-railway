# Copy this file to .env.local and fill in your values

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# PostgreSQL (Railway auto-fills these when you add a Postgres service)
PGHOST=localhost
PGPORT=5432
PGDATABASE=chatbot
PGUSER=postgres
PGPASSWORD=postgres

# Redis (Railway auto-fills REDIS_URL when you add a Redis service)
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
PORT=3000
